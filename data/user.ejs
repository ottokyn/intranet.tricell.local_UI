<%- include('../masterframe/head.html') %>

    <% if (userId) { %>
        <%- include('../masterframe/loggedinmenu_css.html') %>
            <%- include('../masterframe/loggedinmenu_js.html') %>
                <div id="loggedinMenuLayer">
                    <div id="userinfo">
                        <b>User info:</b><br />
                        Employee Code: <%= cookieemployeecode %> <br />
                            Name: <%= cookiename %> <br />
                                Login times: <%= cookielogintimes %> <br />
                                    Last login: <%= cookielastlogin %> <br />
                    </div>

                    <div id="chatbutton">
                        <a href="javascript:void(0)" onClick="javascript:showChatLayer();"
                            style="color:#ffffff;text-decoration:none;">Chat <span id="chatnumber">0</span></a>
                    </div>

                    <div id="chatLayer">
                        <div id="chatLayerMessages"></div>
                        <div id="chatLayerForm">
                            <div style="width:230px;text-align:left;font-size:11px;color:#ffffff;">Write message:
                                <form action="/" id="chatform">
                                    <input type="hidden" name="MAX_FILE_SIZE" value="50000000" />
                                    <textarea name="chatmessage" id="chatmessage" wrap="hard"
                                        style="width:230px;height:50px;border:0px;border-radius:5px;"></textarea>
                                    <input type="button" value="Chat"
                                        style="background-color:#cccccc;border:1px;font-size:10px;"
                                        onClick="submitChat()" />
                                </form>
                            </div>
                        </div>
                    </div>

                    <div id="topsecret">
                        <b>TOP SECRET</b><br />MATERIAL
                    </div>

                    <table border="0" cellspacing="0" cellpadding="0">
                        <tr>
                            <td height="1" width="150" bgcolor="#003366"></td>
                        </tr>
                    </table>

                    <div class="loggedinbutton">
                        <a href="javascript:void(0)" onClick="javascript:showCalcLayer();"
                            style="color:#336699;text-decoration:none;">Tricell Calculator</a>
                    </div>

                    <table border="0" cellspacing="0" cellpadding="0">
                        <tr>
                            <td height="1" width="150" bgcolor="#003366"></td>
                        </tr>
                    </table>

                    <div class="loggedinbutton"><a href="/api/personnelregistry"
                            style="color:#336699;text-decoration:none;">User Database</a></div>

                    <table border="0" cellspacing="0" cellpadding="0">
                        <tr>
                            <td height="1" width="150" bgcolor="#003366"></td>
                        </tr>
                    </table>

                    <div class="loggedinbutton"><a href="/api/virusdatabase"
                            style="color:#336699;text-decoration:none;">Research
                            Database</a></div>

                    <table border="0" cellspacing="0" cellpadding="0">
                        <tr>
                            <td height="1" width="150" bgcolor="#003366"></td>
                        </tr>
                    </table>

                    <div class="loggedinbutton">
                        <a href="/api/logout" style="color:#336699;text-decoration:none;">Log out</a>
                    </div>

                    <table border="0" cellspacing="0" cellpadding="0">
                        <tr>
                            <td height="1" width="150" bgcolor="#003366"></td>
                        </tr>
                    </table>
                </div>

                <div id="calcLayer">
                    <h3>Tricell Calculator</h3>
                    <form name="calc">
                        <table id="calculator">
                            <tr>
                                <td class="calccell" colspan="4"><input class="calcdisplay" type="text"
                                        name="display" />
                                </td>
                            </tr>
                            <tr>
                                <td class="calccell"><input class="calcbutton" type="button" value="C"
                                        onClick="resetDisplay()" />
                                </td>
                                <td></td>
                                <td></td>
                                <td class="calccell"><input class="calcbutton" type="button" value="/"
                                        onClick="calc.display.value+='/'"></td>
                            </tr>
                            <tr>
                                <td class="calccell"><input class="calcbutton" type="button" value="7"
                                        onClick="updateDisplay('7')" /></td>
                                <td class="calccell"><input class="calcbutton" type="button" value="8"
                                        onClick="updateDisplay('8')" /></td>
                                <td class="calccell"><input class="calcbutton" type="button" value="9"
                                        onClick="updateDisplay('9')" /></td>
                                <td class="calccell"><input class="calcbutton" type="button" value="*"
                                        onClick="updateDisplay('*')" /></td>
                            </tr>
                            <tr>
                                <td class="calccell"><input class="calcbutton" type="button" value="4"
                                        onClick="updateDisplay('4')" /></td>
                                <td class="calccell"><input class="calcbutton" type="button" value="5"
                                        onClick="updateDisplay('5')" /></td>
                                <td class="calccell"><input class="calcbutton" type="button" value="6"
                                        onClick="updateDisplay('6')" /></td>
                                <td class="calccell"><input class="calcbutton" type="button" value="-"
                                        onClick="updateDisplay('-')" /></td>
                            </tr>
                            <tr>
                                <td class="calccell"><input class="calcbutton" type="button" value="1"
                                        onClick="updateDisplay('1')" /></td>
                                <td class="calccell"><input class="calcbutton" type="button" value="2"
                                        onClick="updateDisplay('2')" /></td>
                                <td class="calccell"><input class="calcbutton" type="button" value="3"
                                        onClick="updateDisplay('3')" /></td>
                                <td class="calccell"><input class="calcbutton" type="button" value="+"
                                        onClick="updateDisplay('+')" /></td>
                            </tr>
                            <tr>
                                <td class="calccell"><input class="calcbutton" type="button" value="0"
                                        onClick="updateDisplay('0')" /></td>
                                <td></td>
                                <td></td>
                                <td class="calccell"><input class="calcbutton" type="button" value="="
                                        onClick="calculate()" /></td>
                            </tr>
                        </table>
                    </form>
                </div>
                <% } else { %>
                    <div id="loginLayer">
                        <p>Vänligen logga in för att se intranätet.</p>
                    </div>
                    <% } %>

                        <%- include('../masterframe/header.html') %>
                            <%- menu %>
                                <%- include('../masterframe/infoStart.html')%>
                                    <%- content %>
                                        <%- include('../masterframe/infoStop.html')%>
                                            <%- include('../masterframe/footer.html') %>
                                                <%- include('../masterframe/bottom.html') %>